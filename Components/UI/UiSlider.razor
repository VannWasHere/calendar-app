<label class="ui-slider"><span>@Label <output>@Value</output></span><input type="range" min="@Min" max="@Max" step="@Step" value="@Value" @oninput="Changed" /></label>
@code { [Parameter] public string Label { get; set; } = string.Empty; [Parameter] public int Value { get; set; } [Parameter] public int Min { get; set; } [Parameter] public int Max { get; set; } = 100; [Parameter] public int Step { get; set; } = 1; [Parameter] public EventCallback<int> ValueChanged { get; set; } private Task Changed(ChangeEventArgs e) => ValueChanged.InvokeAsync(int.TryParse(e.Value?.ToString(), out var v) ? v : Value); }
