@inject IJSRuntime JS
<button @ref="toggleButton" type="button" class="ui-icon-button" data-theme-toggle="true" title="Toggle theme" aria-label="Toggle dark mode" @onclick="Toggle"><i class="bi bi-circle-half"></i></button>
@code {
    private ElementReference toggleButton;
    private async Task Toggle() => await JS.InvokeVoidAsync("roomBook.toggleTheme", toggleButton);
}
