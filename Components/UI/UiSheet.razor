@if (Open) { <div class="ui-overlay" @onclick="Close"><aside class="ui-sheet @Side" role="dialog" aria-modal="true" @onclick:stopPropagation><header><h2>@Title</h2><button class="ui-icon-button" @onclick="Close"><i class="bi bi-x-lg"></i></button></header><div>@ChildContent</div></aside></div> }
@code { [Parameter] public bool Open { get; set; } [Parameter] public string Title { get; set; } = string.Empty; [Parameter] public string Side { get; set; } = "right"; [Parameter] public RenderFragment? ChildContent { get; set; } [Parameter] public EventCallback OnClose { get; set; } private Task Close() => OnClose.InvokeAsync(); }
