<div class="ui-page-header">
    <div><nav class="ui-breadcrumb" aria-label="Breadcrumb"><a href="/">Workspace</a><span>/</span><span>@Title</span></nav><h1>@Title</h1>@if (!string.IsNullOrWhiteSpace(Description)) { <p>@Description</p> }</div>
    @if (Actions is not null) { <div class="ui-page-actions">@Actions</div> }
</div>
@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
